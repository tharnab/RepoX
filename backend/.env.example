# GitHub OAuth App credentials
# Get these from: GitHub → Settings → Developer Settings → OAuth Apps
GITHUB_CLIENT_ID=your_client_id_here
GITHUB_CLIENT_SECRET=your_client_secret_here
GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback

# Encryption key for token storage
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=generate_with_command_above

# Session signing key
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=generate_with_command_above

# Database URL (SQLite for development)
DATABASE_URL=sqlite+aiosqlite:///./data/repox.db

# Frontend URL (where to redirect after login)
FRONTEND_URL=http://localhost:3000

# App settings
APP_ENV=development
SESSION_MAX_AGE_DAYS=30